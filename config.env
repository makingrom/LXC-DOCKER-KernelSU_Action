CONFIG_ENV=config.env

# 内核源码地址
KERNEL_SOURCE=https://github.com/xiaoleGun/android_kernel_xiaomi_wayne-4.19
# 内核源码分支
KERNEL_SOURCE_BRANCH=twrp-12
# 内核编译配置
KERNEL_CONFIG=vendor/wayne_defconfig
# 选择要打包的内核镜像文件
# 低端机填Image.gz-dtb
# 高端机可以选择Image.gz，Image
KERNEL_IMAGE_NAME=Image.gz-dtb
# 编译设备的硬件架构 ARM64(x86、x86_64、arm、arm64)
ARCH=arm64
# 生成本地文件不加后缀
ADD_LOCALVERSION_TO_FILENAME=false
# 内核编译链接器，默认可能用 GCC 的 ld，这里强制改用 LLVM 的 ld.lld
EXTRA_CMDS:LD=ld.lld

# 关闭「使用自定义 Clang」，改用下方配置的 AOSP 官方 Clang
USE_CUSTOM_CLANG=true
# 自定义 Clang 的仓库地址 / 分支（因 USE_CUSTOM_CLANG=false，这两个参数无效）
CUSTOM_CLANG_SOURCE=https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86/+archive/refs/heads/${{ env.CLANG_BRANCH }}/clang-${{ env.CLANG_VERSION }}.tar.gz
CUSTOM_CLANG_BRANCH=
# 强制指定 Clang 的「架构前缀」为 ARM64 Linux 标准（而非 Android 专属）
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
# AOSP 官方 Clang 的分支（2022 年内核编译专用分支）
CLANG_BRANCH=master-kernel-build-2022
# AOSP 官方 Clang 的版本号（r450784e 是稳定版）
CLANG_VERSION=r450784e

# 启用 ARM64/ARM32 版本的 GCC 编译器
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
# 关闭「自定义 ARM64 GCC」，用默认版本
USE_CUSTOM_GCC_64=true
CUSTOM_GCC_64_SOURCE=https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/aarch64/aarch64-linux-android-4.9/+archive/refs/tags/android-12.1.0_r27.tar.gz
CUSTOM_GCC_64_BRANCH=
# ARM64 GCC 的命令前缀（比如 aarch64-linux-android-gcc）
CUSTOM_GCC_64_BIN=aarch64-linux-android-
# 同理，控制 32 位 ARM GCC，因你是 ARM64 内核，这部分仅作备用
USE_CUSTOM_GCC_32=true
CUSTOM_GCC_32_SOURCE=https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/arm/arm-linux-androideabi-4.9/+archive/refs/tags/android-12.1.0_r27.tar.gz
CUSTOM_GCC_32_BRANCH=
CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# 关闭 KernelSU 集成
ENABLE_KERNELSU=true
KERNELSU_TAG=main
# 指定要集成的 KernelSU 版本（v0.9.5 是稳定版）
KERNELSU_TAG=v0.9.5
# KernelSU 产物的大小 / 哈希校验值（可选）
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

# 启用 LTO（链接时优化）
DISABLE-LTO=false
# 开启「警告转错误」（-Werror）
DISABLE_CC_WERROR=false
# 不添加 Kprobes 调试配置（KernelSU 部分功能依赖 Kprobes）
ADD_KPROBES_CONFIG=false
# 不添加 OverlayFS 配置（文件系统叠加，KernelSU 挂载模块需要）
ADD_OVERLAYFS_CONFIG=false
# 不自动应用 KernelSU 补丁
APPLY_KSU_PATCH=false
# 编译后删除未使用的内核包
REMOVE_UNUSED_PACKAGES=true

# 不使用自定义 AnyKernel3（内核打包工具）
USE_CUSTOM_ANYKERNEL3=true
CUSTOM_ANYKERNEL3_SOURCE=https://github.com/osm0sis/AnyKernel3
CUSTOM_ANYKERNEL3_BRANCH=master

# 是否开启kvm
# 百分之90的用户用不到kvm，false即可
ENABLE_KVM=false

# 是否需要LLVM=1 LLVM_IAS=1参数
# 取决于你的内核源码，一般是需要的
# 需要填y，不需要填n
LLVM_CONFIG=y

# 是否需要切换python2，一般不需要，false即可
SWITCH_PYTHON=true

# Ccache 缓存
ENABLE_CCACHE=true

# 是否需要dtbo，一般不需要，false即可
NEED_DTBO=false

# 不编译完整的 boot.img（仅生成内核镜像 Image.gz-dtb）
BUILD_BOOT_IMG=false
# 原始 boot.img 的下载地址（用于拼接内核镜像生成新 boot.img）
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/xiaoleGun/KernelSU_action/main/boot/boot.img
